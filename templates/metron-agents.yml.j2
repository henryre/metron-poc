name: "Metron: Agent Dispatch"
on:
  workflow_dispatch:
    inputs:
      issue_number:
        description: "Issue number to implement"
        required: true
      agent:
        description: "Agent harness to run"
        required: true
permissions:
  contents: write
  issues: write
  pull-requests: write
  id-token: write
jobs:
  run:
    uses: {{ metron_repo }}/.github/workflows/_agents.yml@{{ metron_ref }}
    secrets: inherit
    with:
      config-path: metron.toml
      issue_number: ${{ '{{' }} inputs.issue_number {{ '}}' }}
      agent: ${{ '{{' }} inputs.agent {{ '}}' }}
