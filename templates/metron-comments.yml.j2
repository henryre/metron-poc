name: "Metron: Comment Commands"
on:
  issue_comment:
    types: [created]
  pull_request_review_comment:
    types: [created]
permissions:
  contents: write
  issues: write
  pull-requests: write
  id-token: write
jobs:
  handle:
    uses: {{ metron_repo }}/.github/workflows/_comments.yml@{{ metron_ref }}
    secrets: inherit
    with:
      config-path: metron.toml
{% if 'claude' in harnesses %}
  claude:
    if: >-
      github.event_name == 'issue_comment' &&
      contains(github.event.comment.body, '@claude')
    uses: {{ metron_repo }}/.github/workflows/_agent-claude.yml@{{ metron_ref }}
    secrets: inherit
    with:
      config-path: metron.toml
{% endif %}
